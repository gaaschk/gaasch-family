generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js tables ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("pending") // pending | viewer | editor | admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  ownedTrees    Tree[]
  treeMembers   TreeMember[]
  auditLogs     AuditLog[]
  fsToken       FamilySearchToken?
  geniToken     GeniToken?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-tenant Tree ────────────────────────────────────────────
model Tree {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id])
  members     TreeMember[]
  invites     TreeInvite[]
  people      Person[]
  families    Family[]
  settings    Setting[]
  auditLogs   AuditLog[]
  documents   Document[]
  agentTasks  AgentTask[]
  lineageStories LineageStory[]
}

model TreeMember {
  id        String   @id @default(cuid())
  treeId    String
  userId    String
  role      String   @default("viewer") // viewer | editor | admin
  createdAt DateTime @default(now())

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([treeId, userId])
}

model TreeInvite {
  id          String    @id @default(cuid())
  treeId      String
  email       String
  role        String    @default("viewer")
  token       String    @unique @default(cuid())
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─── Genealogy ────────────────────────────────────────────────────
model Person {
  id          String   @id @default(cuid())
  treeId      String
  gedcomId    String?
  firstName   String?
  lastName    String?
  maidenName  String?
  gender      String?  // M | F | U
  birthDate   String?
  birthPlace  String?
  birthLat    Float?
  birthLng    Float?
  deathDate   String?
  deathPlace  String?
  deathLat    Float?
  deathLng    Float?
  occupation  String?
  notes       String?
  narrative   String?
  portraitId  String?
  fsPid       String?  // FamilySearch person ID (once linked)
  historicalEventsJson String? // JSON array of historical events
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tree              Tree              @relation(fields: [treeId], references: [id], onDelete: Cascade)
  childInFamilies   FamilyChild[]
  husbandInFamilies Family[]          @relation("Husband")
  wifeInFamilies    Family[]          @relation("Wife")
  fsMatches         FamilySearchMatch[]
  documents         Document[]
  portrait          Document?         @relation("Portrait", fields: [portraitId], references: [id])
  auditLogs         AuditLog[]

  @@unique([treeId, gedcomId])
  @@index([treeId, lastName, firstName])
  @@index([treeId, birthPlace])
  @@index([treeId, birthDate])
}

model Family {
  id         String   @id @default(cuid())
  treeId     String
  gedcomId   String?
  husbandId  String?
  wifeId     String?
  marriageDate  String?
  marriagePlace String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tree     Tree          @relation(fields: [treeId], references: [id], onDelete: Cascade)
  husband  Person?       @relation("Husband", fields: [husbandId], references: [id])
  wife     Person?       @relation("Wife", fields: [wifeId], references: [id])
  children FamilyChild[]

  @@unique([treeId, gedcomId])
}

model FamilyChild {
  id       String @id @default(cuid())
  familyId String
  personId String

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([familyId, personId])
}

// ─── Record Hints ─────────────────────────────────────────────────
model FamilySearchMatch {
  id         String   @id @default(cuid())
  personId   String
  source     String   @default("familysearch") // familysearch | wikitree | geni
  externalId String   // FS pid, WikiTree id, Geni profile id
  matchData  String   // JSON blob of matched fields
  status     String   @default("pending") // pending | accepted | dismissed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, source, externalId])
  @@index([personId, source])
}

// ─── OAuth Tokens ─────────────────────────────────────────────────
model FamilySearchToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GeniToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Documents / Media ────────────────────────────────────────────
model Document {
  id           String   @id @default(cuid())
  treeId       String
  personId     String?
  s3Key        String   @unique
  filename     String
  mimeType     String
  sizeBytes    Int
  category     String   @default("other") // photo | certificate | letter | other
  caption      String?
  portraitScore Float?  // Haiku vision quality score 0-1
  isPortrait   Boolean  @default(false)
  uploadedById String
  createdAt    DateTime @default(now())

  tree   Tree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id])
  portraitFor Person[] @relation("Portrait")

  @@index([treeId])
  @@index([personId])
}

// ─── AI Research Agent ────────────────────────────────────────────
model AgentTask {
  id         String   @id @default(cuid())
  treeId     String
  triggeredBy String  // userId
  status     String   @default("pending") // pending | running | completed | failed
  taskType   String   // research | geocode | narrative-batch
  inputJson  String   // task parameters
  resultJson String?  // task output
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tree     Tree            @relation(fields: [treeId], references: [id], onDelete: Cascade)
  proposed ProposedPerson[]

  @@index([treeId, status])
}

model ProposedPerson {
  id           String   @id @default(cuid())
  treeId       String
  agentTaskId  String
  source       String   // familysearch | geni | manual
  externalId   String   // source person ID
  proposedData String   // JSON: name, dates, places, relationships
  status       String   @default("pending") // pending | accepted | rejected
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentTask AgentTask @relation(fields: [agentTaskId], references: [id], onDelete: Cascade)

  // rejected proposals never deleted — they act as permanent "don't re-propose" signals
  @@unique([treeId, source, externalId])
  @@index([treeId, status])
}

// ─── Lineage Stories ──────────────────────────────────────────────
model LineageStory {
  id         String   @id @default(cuid())
  treeId     String
  title      String
  lineType   String   // paternal | maternal | custom
  personIds  String   // JSON array of person IDs in order
  narrative  String?
  shareToken String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@index([shareToken])
}

// ─── Settings ─────────────────────────────────────────────────────
model Setting {
  id        String   @id @default(cuid())
  treeId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@unique([treeId, key])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Audit Log ────────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  treeId     String
  userId     String
  personId   String?
  action     String   // create | update | delete | generate-narrative | import | export
  entityType String   // person | family | document | member | setting
  entityId   String?
  oldJson    String?
  newJson    String?
  createdAt  DateTime @default(now())

  tree   Tree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id])
  person Person? @relation(fields: [personId], references: [id])

  @@index([treeId, createdAt])
}
